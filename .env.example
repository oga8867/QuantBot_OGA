# =============================================================================
# .env.example - 환경변수 템플릿
# =============================================================================
# 이 파일을 복사하여 .env로 저장하고, 실제 API 키를 입력하세요.
# .env 파일은 절대 git에 커밋하지 마세요!
#
# 대시보드 설정 탭에서 API 키를 입력하면 .env에 자동 저장됩니다.
# 이 파일은 수동 설정 시 참고용 템플릿입니다.
# =============================================================================

# ─── FRED API 키 (거시경제 데이터 수집용, 무료) ───
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ─── DART API 키 (한국 공시 데이터, 무료) ───
# 발급: https://opendart.fss.or.kr
# DART_API_KEY=your_dart_api_key_here

# ═══════════════════════════════════════════════════════════════
# 브로커 API 키 (실거래용)
# ═══════════════════════════════════════════════════════════════

# ─── 한국투자증권 (KIS) ───
# 한국 시장 (KOSPI/KOSDAQ) 매매에 사용
#
# 시작 방법:
# 1. 한국투자증권 계좌 개설
# 2. https://apiportal.koreainvestment.com 에서 API 신청
# 3. APP KEY, APP SECRET 발급
# 4. 모의투자 먼저 신청하여 테스트
#
# KIS_APP_KEY=your_app_key
# KIS_APP_SECRET=your_app_secret
# KIS_ACCOUNT=50012345-01

# ─── Alpaca Markets ───
# 미국 시장 (NYSE/NASDAQ) 매매에 사용
#
# 시작 방법:
# 1. https://alpaca.markets 에서 계정 생성 (무료)
# 2. 대시보드에서 API Key, Secret Key 발급
# 3. Paper Trading으로 먼저 테스트!
#
# ALPACA_API_KEY=your_alpaca_key
# ALPACA_SECRET_KEY=your_alpaca_secret

# ═══════════════════════════════════════════════════════════════
# 알림 설정
# ═══════════════════════════════════════════════════════════════

# ─── Telegram Bot ───
# 발급: BotFather(@BotFather)에게 /newbot 명령
# Chat ID: @userinfobot에게 메시지 보내서 확인
# TELEGRAM_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# ─── Discord Webhook ───
# 서버 설정 → 연동 → 웹후크 → 새 웹후크 → URL 복사
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
